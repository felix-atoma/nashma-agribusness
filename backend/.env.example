# ── Database ─────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/nashma?retryWrites=true&w=majority

# ── Auth ──────────────────────────────────────────────────────────────────
JWT_SECRET=your_64_char_random_secret_here
JWT_EXPIRES_IN=7d

# ── Server ────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── CORS — comma-separated list of allowed origins ────────────────────────
CLIENT_URLS=http://localhost:5173,https://www.nashmaagribusiness.com

# ── Frontend URL (used in order callback & emails) ────────────────────────
CLIENT_URL=http://localhost:5173

# ── Email (Gmail SMTP with App Password) ─────────────────────────────────
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=your_16_char_app_password
CLIENT_EMAIL=info@nashmaagribusiness.com
# Email address that receives new order notifications (defaults to nashmafarms@gmail.com)
NOTIFY_EMAIL=nashmafarms@gmail.com

